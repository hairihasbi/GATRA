rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Sessions Rules ---
    match /sessions/{sessionId} {
      allow get: if isSignedIn() && isValidId(sessionId);
      allow list: if false; // Prevention of session leaks

      function isValidSession(data) {
        return data.hostId is string && 
               data.activeLab is string &&
               data.createdAt is timestamp;
      }

      allow create: if isSignedIn() && 
                      isValidSession(incoming()) && 
                      incoming().hostId == request.auth.uid &&
                      incoming().createdAt == request.time;

      allow update: if isSignedIn() && (
        // Action: Host Update State
        (existing().hostId == request.auth.uid && 
         incoming().hostId == existing().hostId &&
         incoming().diff(existing()).affectedKeys().hasOnly(['activeLab', 'labState', 'updatedAt']) &&
         incoming().updatedAt == request.time)
      );

      // --- Participants Rules ---
      match /participants/{participantId} {
        allow read: if isSignedIn() && isValidId(participantId);
        allow list: if isSignedIn();

        function isValidParticipant(data) {
          return data.uid is string && 
                 data.name is string && data.name.size() <= 32 &&
                 data.role in ['host', 'student'] &&
                 data.joinedAt is timestamp;
        }

        allow create: if isSignedIn() && 
                        participantId == request.auth.uid &&
                        isValidParticipant(incoming()) &&
                        incoming().uid == request.auth.uid &&
                        incoming().joinedAt == request.time;

        allow update: if isSignedIn() && 
                        participantId == request.auth.uid &&
                        incoming().uid == existing().uid &&
                        incoming().role == existing().role &&
                        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'updatedAt']);
      }
    }
  }
}
